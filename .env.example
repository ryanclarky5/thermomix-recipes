# Claude API key (server-side only — no VITE_ prefix, never exposed to browser)
ANTHROPIC_API_KEY=sk-ant-...

# Your Cookidoo _oauth2_proxy cookie value
COOKIDOO_TOKEN=...

# Cookidoo locale — adjust if your account is on a different region
# Common values: ch-de (Switzerland), de-DE (Germany), en-GB (UK)
COOKIDOO_LOCALE=ch-de

# Cookidoo base URL
COOKIDOO_BASE_URL=https://cookidoo.ch

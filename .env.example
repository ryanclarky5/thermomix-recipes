# Claude API key (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Cookidoo credentials — replaces the old COOKIDOO_TOKEN cookie approach
COOKIDOO_EMAIL=your@email.com
COOKIDOO_PASSWORD=yourpassword

# Cookidoo locale — adjust if your account is on a different region
# ch-de = Switzerland (German), de-DE = Germany, en-GB = UK
COOKIDOO_LOCALE=ch-de

# Cookidoo base URL
COOKIDOO_BASE_URL=https://cookidoo.ch
